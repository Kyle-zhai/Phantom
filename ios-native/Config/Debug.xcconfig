// Debug build. Phantom is fully on-device (Vision OCR + CoreML + SwiftData);
// no backend. The app bundle id is set in project.yml — a distinct ".debug"
// id isn't used here because the widget extension id would also need a matching
// per-config suffix (an extension id must be prefixed by its host app's id),
// which isn't worth the churn for local builds.

SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG

DEVELOPMENT_TEAM = 7N337R6J9M
